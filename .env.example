APP_ENV=development
LOG_FORMAT=plain
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# local keeps JSON files under DATA_DIR. Use supabase for deployed MVP state.
STORAGE_BACKEND=local
DATA_DIR=./data

# embedded is convenient for local dev. Use external for deployed API containers.
PIPELINE_WORKER_MODE=embedded
PIPELINE_WORKER_POLL_SECONDS=2.0
PIPELINE_SSE_POLL_SECONDS=1.0
PIPELINE_REQUEUE_INTERRUPTED_RUNS=true

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
TRANSCRIPT_WORKERS=8
SUMMARY_WORKERS=5

# Optional error reporting. Requires sentry-sdk to be installed in the image.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
