RAILWAY_DOCKERFILE_PATH=backend/Dockerfile

APP_ENV=production
APP_PROCESS=api
LOG_FORMAT=json
LOG_LEVEL=INFO

# Include every deployed frontend origin that can call the API.
CORS_ORIGINS=https://traceai.online,https://<cloudflare-pages-project>.pages.dev

STORAGE_BACKEND=supabase
PIPELINE_WORKER_MODE=external
PIPELINE_SSE_POLL_SECONDS=1.0
PIPELINE_REQUEUE_INTERRUPTED_RUNS=true

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<secret>
SUPABASE_JWT_SECRET=<secret>
SUPABASE_JWT_AUDIENCE=authenticated

MINIMAX_API_KEY=<secret>
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
TRANSCRIPT_WORKERS=4
SUMMARY_WORKERS=5

IPROYAL_PROXY_HOST=geo.iproyal.com:12321
IPROYAL_PROXY_USER=<secret>
IPROYAL_PROXY_PASS=<secret>
WEBSHARE_PROXY_USER=<secret>
WEBSHARE_PROXY_PASS=<secret>
PROXY_MAX_ATTEMPTS=5
PROXY_SESSION_LIFETIME_MIN=10
PROXY_BLOCKLIST_TTL_HOURS=6

SUPABASE_REQUEST_RETRIES=3
SUPABASE_RETRY_DELAY_SECONDS=0.5

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
