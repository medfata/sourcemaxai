RAILWAY_DOCKERFILE_PATH=backend/Dockerfile

APP_ENV=production
APP_PROCESS=api
LOG_FORMAT=json
LOG_LEVEL=INFO

# Include every deployed frontend origin that can call the API.
CORS_ORIGINS=https://traceai.online,https://<cloudflare-pages-project>.pages.dev

STORAGE_BACKEND=supabase
PIPELINE_WORKER_MODE=external
PIPELINE_SSE_POLL_SECONDS=1.0
PIPELINE_REQUEUE_INTERRUPTED_RUNS=true

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<secret>
SUPABASE_JWT_SECRET=<secret>
SUPABASE_JWT_AUDIENCE=authenticated

MINIMAX_API_KEY=<secret>
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
TRANSCRIPT_WORKERS=8
SUMMARY_WORKERS=5

# Optional, but recommended for production YouTube metadata fetches from hosted IPs.
# Base64 of a YouTube-only Netscape-format cookies.txt export.
YTDLP_COOKIES_B64=
# Alternative to YTDLP_COOKIES_B64 when you provide a cookie file in the container.
YTDLP_COOKIES_PATH=

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
